{
  "name": "@omicronenergy/oscd-editor-publisher",
  "version": "0.0.1",
  "description": "OpenSCD Editor Plugin for working with IEC 61850 SCL files.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OMICRONEnergyOSS/oscd-editor-publisher.git"
  },
  "bugs": {
    "url": "https://github.com/OMICRONEnergyOSS/oscd-editor-publisher/issues"
  },
  "homepage": "https://openscd.org",
  "keywords": [
    "OpenSCD",
    "iec81650"
  ],
  "contributors": [
    "OMICRON Electronics GmbH"
  ],
  "license": "Apache-2.0",
  "exports": {
    ".": "./dist/oscd-editor-publisher.js",
    "./oscd-editor-publisher.js": "./dist/oscd-editor-publisher.js"
  },
  "files": [
    "/dist/",
    "!/dist/*.spec.*",
    "!/dist/*.test.*"
  ],
  "scripts": {
    "lint": "oscd lint",
    "format": "oscd lint --format",
    "analyze": "oscd analyze",
    "build": "oscd build",
    "bundle": "oscd bundle",
    "test": "oscd test",
    "test:watch": "oscd test --watch",
    "test:visual": "oscd test --visual",
    "test:update": "oscd test --update",
    "start": "oscd start",
    "start:bundle": "oscd start-bundle",
    "updates": "oscd updates",
    "deploy": "oscd deploy",
    "prepare": "oscd install-hooks"
  },
  "dependencies": {
    "@lit/localize": "^0.12.2",
    "@omicronenergy/oscd-menu-open": "^0.0.6",
    "@omicronenergy/oscd-menu-save": "^0.0.2",
    "@omicronenergy/oscd-shell": "^0.0.13",
    "@omicronenergy/oscd-ui": "^0.0.13",
    "@open-wc/scoped-elements": "^3.0.6",
    "@openscd/oscd-api": "^0.1.6",
    "@openscd/scl-lib": "^2.0.0",
    "lit": "^3.3.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@omicronenergy/oscd-tooling": "^0.0.2",
    "@open-wc/testing": "^4.0.0",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-visual-regression": "0.9.0",
    "@webcomponents/scoped-custom-element-registry": "^0.0.10",
    "sinon": "^21.1.2"
  },
  "overrides": {
    "@web/test-runner-playwright": {
      "playwright": "1.59.1"
    }
  },
  "customElements": "custom-elements.json",
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write",
      "eslint"
    ]
  }
}
